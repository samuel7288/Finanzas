PORT=4000
FRONTEND_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finanzas?schema=public
APP_DEFAULT_EMAIL=local@finova.app
GOOGLE_CLIENT_ID=
